# Copy to .env.local — never commit .env.local
#
# Guest/demo mode works without any of these values. Set them to enable
# authenticated mode with Supabase Auth + Postgres-backed persistence.

# ── Supabase Auth (required for authenticated mode) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Prisma / Postgres (required for authenticated mode) ───────────
# DATABASE_URL should be the pooled connection string (used by the Prisma client at runtime).
# DIRECT_URL should be the direct connection string (used by Prisma CLI for migrations).
DATABASE_URL=
DIRECT_URL=

# ── Python FastAPI agent (optional) ──────────────────────────────
# Default: http://localhost:8000
# AGENT_URL=http://localhost:8000

# ── Redis (recommended for multi-instance deploys) ────────────────
# If not set, the global daily rate limit falls back to per-instance in-memory storage.
# UPSTASH_REDIS_REST_URL=https://<your-upstash-endpoint>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# ── Demo rate-limit overrides (optional; defaults shown) ──────────
# DEMO_AI_GLOBAL_DAILY_LIMIT=120
# DEMO_GEN_SESSION_MINUTE_LIMIT=4
# DEMO_GEN_SESSION_DAILY_LIMIT=20
# DEMO_GEN_IP_MINUTE_LIMIT=20
# DEMO_GEN_IP_DAILY_LIMIT=40
# DEMO_TUTOR_SESSION_MINUTE_LIMIT=10
# DEMO_TUTOR_SESSION_DAILY_LIMIT=20
# DEMO_TUTOR_IP_MINUTE_LIMIT=60
# DEMO_TUTOR_IP_DAILY_LIMIT=40
# DEMO_PLANNER_SESSION_MINUTE_LIMIT=2
# DEMO_PLANNER_SESSION_DAILY_LIMIT=10
# DEMO_PLANNER_IP_MINUTE_LIMIT=10
# DEMO_PLANNER_IP_DAILY_LIMIT=20
# DEMO_STUDY_ASSIST_SESSION_MINUTE_LIMIT=6
# DEMO_STUDY_ASSIST_SESSION_DAILY_LIMIT=30
# DEMO_STUDY_ASSIST_IP_MINUTE_LIMIT=30
# DEMO_STUDY_ASSIST_IP_DAILY_LIMIT=60
# DEMO_RESET_SESSION_BURST_LIMIT=1
# DEMO_RESET_SESSION_DAILY_LIMIT=20
# DEMO_RESET_IP_DAILY_LIMIT=100
