# Copy to .env and fill in the keys you want to use.
# At least one provider key is required (or Ollama must be running).

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google (Gemini) ───────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Groq (free tier available) ────────────────────────────────────
GROQ_API_KEY=

# ── Ollama local (no key needed) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Ollama cloud (get key at https://ollama.com/settings/api-keys) ─
OLLAMA_API_KEY=

# ── Default model (used when the frontend sends no model preference) ──
# Format: provider/model-name
DEFAULT_MODEL=openai/gpt-4o-mini

# ── Planner (v1, English-only) ─────────────────────────────────────────
# Confidence threshold for accepting LLM plans (0..1). Below this, the planner
# falls back to the deterministic heuristic baseline. Calibrated from the
# 30-case evalset — see agent/docs/PLANNER_v1.md.
# PLANNER_CONFIDENCE_THRESHOLD=0.55

# ── Langfuse tracing (optional; fail-open if not set) ─────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Phase 3: Hybrid retrieval (optional; falls back to metadata-only if unset) ──
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# HYBRID_STRONG_HIT_THRESHOLD=8
# HYBRID_ALPHA=0.6
